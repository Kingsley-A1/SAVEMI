# Database (CockroachDB / PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host:port/database?sslmode=require"

# Cloudflare R2 Storage
# These names must match exactly what src/lib/r2.ts reads at runtime.
CF_ACCOUNT_ID="your-cloudflare-account-id"
CF_ACCESS_KEY_ID="your-r2-access-key"
CF_SECRET_ACCESS_KEY="your-r2-secret-key"
CF_BUCKET="your-bucket-name"
CF_PUBLIC_BASE_URL="https://your-r2-public-url.r2.dev"

# NextAuth (Auth.js v5)
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin seed credentials (used by prisma/seed.cjs — development only)
# ADMIN_EMAIL must be set; there is no fallback in production.
# ADMIN_ACCESS_CODE or ADMIN_PASSWORD must be exactly 6 characters.
ADMIN_EMAIL="admin@savemi.org"
ADMIN_PASSWORD="CHANGE"
ADMIN_NAME="SAVEMI Admin"
